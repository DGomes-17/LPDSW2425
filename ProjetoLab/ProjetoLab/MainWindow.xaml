<Window x:Class="ProjetoLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Painel Principal - Projeto LPDS"
        Height="600" Width="1000"
        Background="white"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="white"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="10" ShadowDepth="2" Color="#AA000000"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Background="#8B0000" VerticalAlignment="Stretch" Orientation="Vertical">
            <TextBlock Text="Menu" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,30"/>

            <Button Content="Utilizador" Style="{StaticResource NavButtonStyle}" Click="AbrirUtilizador_Click"/>
            <Button Content="Alunos" Style="{StaticResource NavButtonStyle}" Click="AbrirAlunos_Click"/>
            <Button Content="Grupos" Style="{StaticResource NavButtonStyle}" Click="AbrirGrupos_Click"/>
            <Button Content="Tarefas" Style="{StaticResource NavButtonStyle}" Click="AbrirTarefas_Click"/>
            <Button Content="Avaliações" Style="{StaticResource NavButtonStyle}" Click="AbrirAvaliacoes_Click"/>
            <Button Content="Pauta Final" Style="{StaticResource NavButtonStyle}" Click="AbrirPauta_Click"/>
        </StackPanel>

        <!-- Conteúdo principal dinâmico -->
        <ContentControl x:Name="ConteudoPrincipal" Grid.Column="1" Margin="20" />
    </Grid>
</Window>
