<UserControl x:Class="ProjetoLab.Views.AlunoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetoLab.Views"
        mc:Ignorable="d"
        
        Background="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Gestão de Alunos" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="DarkRed" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10"/>

        <!-- Pesquisa -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10" HorizontalAlignment="Center">
            <TextBlock Text="Número:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="150" Text="{Binding NumeroPesquisa, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Tabela de alunos -->
        <DataGrid x:Name="AlunoDataGrid" Grid.Row="2"
                  ItemsSource="{Binding AlunosFiltrados}"
                  SelectedItem="{Binding AlunoSelecionado}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="MistyRose"
                  BorderBrush="DarkRed"
                  BorderThickness="1"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="*"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botões -->
        <Border Grid.Row="3"
                Background="#FFEFEFEF" 
                BorderBrush="DarkRed" 
                BorderThickness="1" 
                CornerRadius="5" 
                Margin="0,15,0,0"
                Padding="10"
                HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Content="Adicionar" Width="100" Margin="10,0"
                        Background="#FFB22222" Foreground="White"
                        Command="{Binding AdicionarCommand}"/>
                <Button Content="Remover" Width="100" Margin="10,0"
                        Background="#FF8B0000" Foreground="White"
                        Command="{Binding RemoverCommand}"/>
                <Button Content="Guardar" Width="100" Margin="10,0"
                        Background="#FFCD5C5C" Foreground="White"
                        Command="{Binding GuardarCommand}"/>
                <Button Content="Importar Alunos" Width="130" Margin="10,0"
                        Background="DarkRed" Foreground="White"
                        Command="{Binding ImportarAlunosCommand}" />

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
