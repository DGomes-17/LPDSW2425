<UserControl x:Class="ProjetoLab.Views.AvaliacaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:ProjetoLab.ViewModels"
             Background="White">

    <UserControl.DataContext>
        <viewmodels:AvaliacaoViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Registo de Avaliações"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkRed"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Formulário -->
        <Border Grid.Row="1" Padding="10" BorderBrush="DarkRed" BorderThickness="1"
                CornerRadius="5" Background="#FFF8F8F8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Grupo" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Grupos}" 
                              DisplayMemberPath="Nome"
                              SelectedItem="{Binding GrupoSelecionado}"
                              Width="180"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Tarefa" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Tarefas}" 
                              DisplayMemberPath="Titulo"
                              SelectedItem="{Binding TarefaSelecionada}"
                              Width="180"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Nota" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Nota}" Width="100"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Adicionar"
                        Command="{Binding AdicionarAvaliacaoCommand}"
                        Background="#B22222" Foreground="White"
                        Margin="10,20,0,0" Width="120"/>
            </Grid>
        </Border>

        <!-- Lista + Botões -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">

            <!-- Tabela -->
            <DataGrid ItemsSource="{Binding Avaliacoes}"
                      SelectedItem="{Binding AvaliacaoSelecionada}"
                      AutoGenerateColumns="False"
                      AlternatingRowBackground="MistyRose"
                      BorderBrush="DarkRed"
                      BorderThickness="1"
                      Height="250">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Grupo" Binding="{Binding Grupo.Nome}" Width="2*"/>
                    <DataGridTextColumn Header="Tarefa" Binding="{Binding Tarefa.Titulo}" Width="2*"/>
                    <DataGridTextColumn Header="Nota" Binding="{Binding Nota}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Botões -->
            <Border Background="#FFEFEFEF" BorderBrush="DarkRed" BorderThickness="1"
                    CornerRadius="5" Padding="10" HorizontalAlignment="Center" Margin="0,15,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Remover" Width="100" Margin="10,0"
                            Command="{Binding RemoverAvaliacaoCommand}"
                            Background="#8B0000" Foreground="White"/>
                    <Button Content="Guardar" Width="100" Margin="10,0"
                            Command="{Binding GuardarAvaliacoesCommand}"
                            Background="#B22222" Foreground="White"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
