<UserControl x:Class="ProjetoLab.Views.GrupoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:ProjetoLab.ViewModels"
             Background="White">

    <UserControl.DataContext>
        <viewmodels:GrupoViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Gestão de Grupos"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="DarkRed"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de Grupos -->
            <DataGrid ItemsSource="{Binding Grupos}" SelectedItem="{Binding GrupoSelecionado, Mode=TwoWay}"
                      AutoGenerateColumns="False" Grid.Column="0" Margin="0,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Gestão de Alunos no Grupo -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Alunos no Grupo" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox ItemsSource="{Binding AlunosNoGrupo}" DisplayMemberPath="Nome"
                         SelectedItem="{Binding AlunoSelecionadoParaRemover, Mode=TwoWay}"
                         Height="150"/>

                <StackPanel Orientation="Horizontal" Margin="10,10,0,5">
                    <TextBlock Text="Número do Aluno:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Width="300"
                             ToolTip="Introduza o número do aluno"
                             Text="{Binding NumeroPesquisa, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="60,5,0,0">
                    <ComboBox ItemsSource="{Binding AlunosDisponiveis}" DisplayMemberPath="Nome"
                              SelectedItem="{Binding AlunoSelecionadoParaAdicionar, Mode=TwoWay}" Width="200"/>
                    <Button Content="Adicionar" Margin="10,0,0,0" Width="95"
                            Background="DarkRed" Foreground="White"
                            Command="{Binding AdicionarAlunoAoGrupoCommand}"/>
                </StackPanel>

                <Button Content="Remover Selecionado" Margin="0,10,0,0" Width="180"
                        Background="DarkRed" Foreground="White"
                        Command="{Binding RemoverAlunoDoGrupoCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Botões -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Adicionar Grupo" Width="130" Margin="10,0"
                    Background="DarkRed" Foreground="White"
                    Command="{Binding AdicionarGrupoCommand}"/>
            <Button Content="Remover Grupo" Width="130" Margin="10,0"
                    Background="DarkRed" Foreground="White"
                    Command="{Binding RemoverGrupoCommand}"/>
            <Button Content="Guardar" Width="130" Margin="10,0"
                    Background="DarkRed" Foreground="White"
                    Command="{Binding GuardarGruposCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
