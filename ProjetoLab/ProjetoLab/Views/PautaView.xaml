<UserControl x:Class="ProjetoLab.Views.PautaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:ProjetoLab.ViewModels"
             xmlns:local="clr-namespace:ProjetoLab.Views"
             Background="White">

    <UserControl.DataContext>
        <viewmodels:PautaViewModel />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Pauta Final"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="DarkRed"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Tabela -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding PautaFinal}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="MistyRose"
                  BorderBrush="DarkRed"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="*"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*"/>
                <DataGridTextColumn Header="Nota Final" Binding="{Binding NotaFinal}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botão Ver Histograma -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Ver Histograma" Width="150" Height="35"
                    Background="DarkRed" Foreground="White"
                    Click="VerHistograma_Click"/>
        </StackPanel>
    </Grid>
</UserControl>