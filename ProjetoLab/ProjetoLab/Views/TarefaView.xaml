<UserControl x:Class="ProjetoLab.Views.TarefaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título da secção -->
        <TextBlock Text="Gestão de Tarefas"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="DarkRed"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Tabela de tarefas -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Tarefas}"
                  SelectedItem="{Binding TarefaSelecionada}"
                  AutoGenerateColumns="False"
                  AlternatingRowBackground="MistyRose"
                  BorderBrush="DarkRed"
                  BorderThickness="1"
                  Margin="0,10,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="2*"/>
                <DataGridTextColumn Header="Peso" Binding="{Binding Peso}" Width="*"/>
                <DataGridTextColumn Header="Início" Binding="{Binding DataHoraInicio}" Width="*"/>
                <DataGridTextColumn Header="Fim" Binding="{Binding DataHoraFim}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botões de ação -->
        <Border Grid.Row="2"
                Background="#FFEFEFEF"
                BorderBrush="DarkRed"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10"
                HorizontalAlignment="Center"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Adicionar" Width="100" Margin="5" Command="{Binding AdicionarTarefaCommand}"/>
                <Button Content="Remover" Width="100" Margin="5" Command="{Binding RemoverTarefaCommand}"/>
                <Button Content="Guardar" Width="100" Margin="5" Command="{Binding GuardarTarefasCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
